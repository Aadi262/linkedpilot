{
    "manifest_version": 3,
    "name": "LinkedPilot Session Connector",
    "version": "1.0.0",
    "description": "Connect your LinkedIn account to LinkedPilot",
    "permissions": [
        "cookies",
        "activeTab",
        "storage"
    ],
    "host_permissions": [
        "https://*.linkedin.com/*",
        "http://localhost:3000/*",
        "https://*.vercel.app/*"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_title": "LinkedPilot"
    },
    "background": {
        "service_worker": "background.js"
    },
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}